# SECURITY: Storage holds application logs and other internal artifacts.
# This directory must never be web-accessible. The webroot is `public/`,
# but this file is an additional safeguard in case someone mis-points
# the document root.

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
