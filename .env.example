# =============================================================================
# Gym Attendance Checker — environment template
# Copy to .env and replace EVERY placeholder before booting in production.
# =============================================================================

# -- Application -------------------------------------------------------------
APP_ENV=production
APP_NAME="Gym Attendance Checker"
APP_URL=https://your-domain.example
APP_TIMEZONE=Asia/Manila
APP_DEBUG=false

# Must be at least 32 random characters. Generate with:
#   php -r "echo bin2hex(random_bytes(32));"
APP_SECRET=REPLACE_WITH_64_HEX_CHARS_FROM_RANDOM_BYTES

# -- Sessions ----------------------------------------------------------------
SESSION_COOKIE_NAME=gym_attendance_session
# MUST be true behind HTTPS in production. Only set false for local HTTP dev.
SESSION_SECURE=true
SESSION_SAMESITE=Lax
SESSION_LIFETIME=7200

# -- Networking --------------------------------------------------------------
# Comma-separated list of trusted reverse proxies. X-Forwarded-For is only
# honored when REMOTE_ADDR is in this list.
TRUSTED_PROXIES=127.0.0.1

# -- Rate limiting / scan behavior -------------------------------------------
DUPLICATE_SCAN_WINDOW_SECONDS=45
CHECKIN_RATE_LIMIT_WINDOW_SECONDS=60
CHECKIN_RATE_LIMIT_MAX_ATTEMPTS=25
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
RATE_LIMIT_RETENTION_DAYS=7
PHOTO_CAPTURE_ENABLED=true
EXPIRY_REMINDER_DAYS=7

# -- Database ----------------------------------------------------------------
# Use a least-privilege account, NOT root. Grant only:
#   SELECT, INSERT, UPDATE, DELETE on the application schema.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=gym_attendance
DB_USER=gym_app_user
DB_PASS=REPLACE_WITH_STRONG_DB_PASSWORD

# -- SMTP --------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=REPLACE_WITH_SMTP_USERNAME
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
SMTP_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@example.com
MAIL_FROM_NAME="Gym Attendance Checker"
ADMIN_ALERT_EMAIL=owner@example.com
